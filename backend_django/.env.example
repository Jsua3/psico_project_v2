# Variables de entorno del backend Django.
# Producción (DJANGO_SETTINGS_MODULE=psychosim.settings.production) las EXIGE y
# rechaza los defaults dev. En desarrollo (settings.local) hay fallbacks en base.py,
# así que en local normalmente NO necesitas un .env (los fallbacks apuntan a la BD docker).

DJANGO_SECRET_KEY=cambia-esto-en-produccion
# DJANGO_SETTINGS_MODULE: módulo de configuración que Django carga. En producción usa .production; en local, .local.
DJANGO_SETTINGS_MODULE=psychosim.settings.production
DJANGO_ALLOWED_HOSTS=tu-dominio.edu.co,localhost
CORS_ALLOWED_ORIGINS=https://tu-dominio.edu.co

DB_NAME=psychosim
DB_USER=psychosim
DB_PASSWORD=cambia-esto-por-un-secreto-fuerte
DB_HOST=localhost
DB_PORT=5433

JWT_SECRET=cambia-esto-por-un-secreto-fuerte-de-al-menos-256-bits
JWT_EXPIRATION_HOURS=8
GOOGLE_OAUTH_CLIENT_ID=tu-client-id-web-de-google.apps.googleusercontent.com
# Opcional: si no se define, cae a JWT_SECRET (igual que Spring). La confidencialidad
# de las bitácoras cifradas depende de que este valor sea fuerte y privado.
REFLECTION_ENCRYPTION_KEY=

# ── AI Assistant (RF-027) ─────────────────────────────────────────────────────
AI_ASSISTANT_PROVIDER=openai
AI_ASSISTANT_API_KEY=cambia-esto-por-tu-clave-de-openai
AI_ASSISTANT_MODEL=gpt-4o-mini
