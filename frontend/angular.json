{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "psychosim-admin-panel": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": { "standalone": true, "style": "scss" }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/psychosim-admin-panel",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles/styles.scss"],
            "scripts": [],
            "allowedCommonJsDependencies": ["phaser", "konva", "howler"]
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "850kb", "maximumError": "1.4mb" },
                { "type": "anyComponentStyle", "maximumWarning": "14kb", "maximumError": "22kb" }
              ],
              "outputHashing": "all"
            },
            "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "psychosim-admin-panel:build:production" },
            "development": { "buildTarget": "psychosim-admin-panel:build:development" }
          },
          "defaultConfiguration": "development",
          "options": { "proxyConfig": "proxy.conf.json" }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:jest",
          "options": { "tsConfig": "tsconfig.spec.json" }
        }
      }
    }
  },
  "cli": {
    "analytics": "5e71ad16-8a1a-4304-89cb-5cb4706a328d"
  }
}
