# =============================================================================
# SIEP / PsychoSim — Variables de entorno requeridas
# Copia este archivo a `.env` (gitignored) y cambia los valores reales.
# docker compose carga `.env` automáticamente desde este directorio.
# =============================================================================

# ── Docker / PostgreSQL ───────────────────────────────────────────────────────
# POSTGRES_PASSWORD: usada por Docker Compose para inicializar el contenedor de la BD.
POSTGRES_PASSWORD=cambia-esto-en-produccion
# DB_PASSWORD: usada por Django para conectarse a la BD (debe coincidir con POSTGRES_PASSWORD).
DB_PASSWORD=cambia-esto-en-produccion

# ── Django ────────────────────────────────────────────────────────────────────
# DJANGO_SECRET_KEY: la que Django lee en producción (settings.production).
DJANGO_SECRET_KEY=cambia-esto-en-produccion
# SECRET_KEY: puede usarse en docker-compose para servicios auxiliares; Django no la lee directamente.
SECRET_KEY=cambia-esto-en-produccion
# DATABASE_URL: alternativa a las variables DB_* separadas (si se define, tiene prioridad en dj-database-url).
DATABASE_URL=postgresql://psychosim:cambia-esto-en-produccion@localhost:5433/psychosim
DJANGO_SETTINGS_MODULE=psychosim.settings.production
DJANGO_ALLOWED_HOSTS=tu-dominio.edu.co

DB_NAME=psychosim
DB_USER=psychosim
DB_HOST=localhost
DB_PORT=5433

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secreto-fuerte-de-al-menos-256-bits
JWT_EXPIRATION_HOURS=8
GOOGLE_OAUTH_CLIENT_ID=tu-client-id-web-de-google.apps.googleusercontent.com
REFLECTION_ENCRYPTION_KEY=cambia-esto-por-un-secreto-fuerte

CORS_ALLOWED_ORIGINS=https://tu-dominio.edu.co

# Redirección HTTPS (pon "false" solo si hay un proxy TLS externo que ya lo maneja)
DJANGO_SECURE_SSL_REDIRECT=true

# ── AI Assistant (RF-027) ─────────────────────────────────────────────────────
AI_ASSISTANT_PROVIDER=openai
AI_ASSISTANT_API_KEY=cambia-esto-por-tu-clave-de-openai
AI_ASSISTANT_MODEL=gpt-4o-mini
