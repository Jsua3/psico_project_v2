# =============================================================================
# SIEP / PsychoSim — Variables de entorno requeridas
# Copia este archivo a `.env` (gitignored) y cambia los valores reales.
# docker compose carga `.env` automáticamente desde este directorio.
# =============================================================================

# ── Docker / PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-postgres-password-here
DB_PASSWORD=your-db-password-here

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://user:pass@localhost:5432/siep
DJANGO_SECRET_KEY=your-django-secret-key-here
DJANGO_SETTINGS_MODULE=psychosim.settings.production
DJANGO_ALLOWED_HOSTS=your-domain.com

DB_NAME=psychosim
DB_USER=psychosim
DB_HOST=localhost
DB_PORT=5433

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-256-bits-long-for-hs256
JWT_EXPIRATION_HOURS=8
REFLECTION_ENCRYPTION_KEY=your-reflection-encryption-key-here

CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# HTTPS redirect (set to "false" only behind a TLS-terminating proxy already handling this)
DJANGO_SECURE_SSL_REDIRECT=true

# ── AI Assistant (RF-027) ─────────────────────────────────────────────────────
AI_ASSISTANT_PROVIDER=openai
AI_ASSISTANT_API_KEY=your-openai-key-here
AI_ASSISTANT_MODEL=gpt-4o-mini
